{
  "name": "@spatio-labs/superellipse",
  "version": "2.0.0",
  "description": "Tailwind CSS plugin + tiny runtime for SwiftUI-accurate squircles and the full CSS corner-shape value set, working in every browser.",
  "main": "./tailwind.js",
  "types": "./tailwind.d.ts",
  "exports": {
    ".": {
      "types": "./tailwind.d.ts",
      "require": "./tailwind.js",
      "default": "./tailwind.js"
    },
    "./tailwind": {
      "types": "./tailwind.d.ts",
      "require": "./tailwind.js",
      "default": "./tailwind.js"
    },
    "./corners": {
      "types": "./corners.d.ts",
      "import": "./corners.mjs",
      "default": "./corners.mjs"
    },
    "./squircle.css": "./squircle.css"
  },
  "files": [
    "tailwind.js",
    "tailwind.d.ts",
    "corners.mjs",
    "corners.d.ts",
    "squircle.css",
    "README.md",
    "superellipse_example.jpg"
  ],
  "sideEffects": [
    "./corners.mjs",
    "*.css"
  ],
  "scripts": {
    "test": "node --test"
  },
  "keywords": [
    "tailwind",
    "tailwindcss",
    "tailwind-plugin",
    "squircle",
    "superellipse",
    "corner-shape",
    "swiftui",
    "continuous-corner",
    "border-radius",
    "css"
  ],
  "author": "Matthew Park",
  "license": "ISC",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/spatio-labs/superellipse.git"
  },
  "homepage": "https://github.com/spatio-labs/superellipse#readme",
  "bugs": {
    "url": "https://github.com/spatio-labs/superellipse/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "tailwindcss": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "tailwindcss": {
      "optional": true
    }
  }
}
